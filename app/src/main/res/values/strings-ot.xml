    <string name="dl_oobe_tooltip" translatable="false">Songs are download to the app\'s private internal storage. To download songs to the external storage, you need to choose a folder first. You can add, change or remove folders, or migrate Internal Downloads to External Downloads later in Settings.</string>
    <string name="dl_rescan_title" translatable="false">Rescan download folders…</string>
